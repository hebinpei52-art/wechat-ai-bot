{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "python",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "Always",
    "restartPolicyMaxRetries": 10,
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --threads 4"
  }
}